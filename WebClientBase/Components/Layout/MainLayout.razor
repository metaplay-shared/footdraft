@inherits LayoutComponentBase
@using WebClientBase.Configuration
@using WebClientBase.Services
@inject IMetaplayConnectionService MetaplayService
@inject NavigationManager NavigationManager
@inject WebClientConfig Config
@implements IDisposable

@* Lightweight, see-through top bar floating over the game. Debug info only.
   pointer-events:none lets taps pass through to the game; the controls cluster
   re-enables pointer events for itself. *@
<header class="fixed top-0 left-0 right-0 z-50" style="pointer-events: none;">
    <div class="container mx-auto px-4 max-w-2xl">
        <div class="flex items-center justify-end h-12" style="padding-top: env(safe-area-inset-top);">
            <!-- Debug info cluster (interactive) -->
            <div class="flex items-center gap-1.5 text-[11px]" style="pointer-events: auto;">
                @if (HeaderBranding != null)
                {
                    @HeaderBranding
                }

                @if (!string.IsNullOrEmpty(GetPlayerIdText()))
                {
                    <span class="px-2 py-1 rounded" style="color: var(--text-muted); background: rgba(0,0,0,0.35); backdrop-filter: blur(4px);">
                        @GetPlayerIdText()
                    </span>
                }

                <div class="flex items-center gap-1.5 px-2 py-1 rounded" style="background: rgba(0,0,0,0.35); backdrop-filter: blur(4px);">
                    <div class="w-1.5 h-1.5 rounded-full @GetConnectionDotClass()"></div>
                    <span style="color: var(--text-secondary);">@GetConnectionText()</span>
                </div>

                @if (MetaplayService.ConnectionState == ConnectionState.Error ||
                     MetaplayService.ConnectionState == ConnectionState.Disconnected)
                {
                    <button class="px-2.5 py-1 rounded font-medium transition-colors"
                            style="background: var(--accent-blue); color: white;"
                            @onclick="OnReconnect">
                        Reconnect
                    </button>
                }
                @if (MetaplayService.ConnectionState == ConnectionState.Connected)
                {
                    <button type="button"
                            class="px-2.5 py-1 rounded font-medium transition-colors"
                            style="background: rgba(239, 68, 68, 0.15); color: var(--accent-red);"
                            @onclick="OnReset">
                        Reset
                    </button>
                }

                @HeaderActions
            </div>
        </div>
    </div>
</header>

<main class="container mx-auto px-4 py-5 max-w-2xl">
    @Body
</main>

@code {
    /// <summary>
    /// Custom branding content for the header. If not provided, uses default branding from WebClientConfig.
    /// </summary>
    [Parameter]
    public RenderFragment? HeaderBranding { get; set; }

    /// <summary>
    /// Additional actions to display in the header (to the right of connection status).
    /// </summary>
    [Parameter]
    public RenderFragment? HeaderActions { get; set; }

    protected override void OnInitialized()
    {
        MetaplayService.OnStateChanged += OnStateChanged;
    }

    private void OnStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private string GetConnectionDotClass()
    {
        return MetaplayService.ConnectionState switch
        {
            ConnectionState.Connected => "bg-green-500",
            ConnectionState.Connecting => "bg-amber-500 animate-pulse",
            ConnectionState.Error => "bg-red-500",
            _ => "bg-zinc-500"
        };
    }

    private string GetConnectionText()
    {
        return MetaplayService.ConnectionState switch
        {
            ConnectionState.Connected => "Connected",
            ConnectionState.Connecting => "Connecting...",
            ConnectionState.Error => "Error",
            _ => "Offline"
        };
    }

    private string GetPlayerIdText()
    {
        return MetaplayService.PlayerId?.ToString() ?? "";
    }

    private async Task OnReconnect()
    {
        await MetaplayService.ConnectAsync();
    }

    private void OnReset()
    {
        if (MetaplayService.Reset())
        {
            NavigationManager.NavigateTo("/", forceLoad: true);
        }
    }

    public void Dispose()
    {
        MetaplayService.OnStateChanged -= OnStateChanged;
    }
}
