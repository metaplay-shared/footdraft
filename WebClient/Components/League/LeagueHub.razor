@if (_showProfile)
{
    <ManagerProfileHub OnClose="@(() => _showProfile = false)" />
}

@code {
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public string InitialMode { get; set; } = "create";

    private System.Timers.Timer? _refreshTimer;
    private System.Timers.Timer? _tickTimer;
    private string _leagueName = "";
    private string _joinCode = "";
    private string _teamName = "";
    private string _mode = "create";
    private bool _hideRatings;                    // hard mode (hide ratings)
    private int _maxPerClub = 1;                  // House rule: max players per club (0 = no limit)
    private Position? _pickPos;

    // House rule: fully custom OVR-cap bands. Each rule is "max N players rated R+"; up to MaxCapRules of them.
    // Editable add/remove rows (no fixed presets) — serialized on demand to the "R:N,R:N" string the server +
    // LeagueDefinition.ParseOvrCaps already understand (highest rating first), see _capBands below.
    private const int MaxCapRules = 5;
    private sealed class CapRule { public int Ovr; public int Max; public CapRule(int ovr, int max) { Ovr = ovr; Max = max; } }
    private readonly List<CapRule> _capRules =
        LeagueDefinition.ParseOvrCaps("90:2,80:3,75:4").Select(c => new CapRule(c.Threshold, c.Max)).ToList();
    private string _capBands => string.Join(",", _capRules.OrderByDescending(r => r.Ovr).Select(r => $"{r.Ovr}:{r.Max}"));

    // Pin-draft House Rule — filters the spin pool by era and/or elite clubs (serialised like CapBands).
    private string _pinEra = "";   // "" = any era; else an Era enum name, e.g. "E2010s"
    private bool   _pinElite;
    private string _draftPin => string.Join(",",
        new[] { string.IsNullOrEmpty(_pinEra) ? "" : $"era:{_pinEra}", _pinElite ? "elite:1" : "" }.Where(s => s.Length > 0));

    private PlayerModel? Player => MetaplayService.PlayerModel;
    private SharedGameConfig? Config => Player?.GameConfig;
    private PlayerLeague Lg => Player!.League;
    private LeagueSnapshot? Snap => Lg.Snapshot;

    private IEnumerable<FormationInfo> Formations => Config?.Formations.Values ?? Enumerable.Empty<FormationInfo>();

    private string NameOf(int teamIndex) =>
        Snap?.Members.FirstOrDefault(m => m.Index == teamIndex)?.Name ?? $"#{teamIndex}";
    private string CrestOf(int teamIndex) =>
        Snap?.Members.FirstOrDefault(m => m.Index == teamIndex)?.Crest ?? "⚽";
    private bool IsBotOf(int teamIndex) =>
        Snap?.Members.FirstOrDefault(m => m.Index == teamIndex)?.IsBot == true;

    // Human-readable time until the next scheduled matchday sim (ticking — a 1s timer repaints the hero).
    private string NextSimText
    {
        get
        {
            if (Snap == null || Snap.NextSimAtMillis <= 0) return "";
            long ms = Snap.NextSimAtMillis - DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
            if (ms <= 0) return "any moment";
            long totalSecs = ms / 1000;
            long h = totalSecs / 3600, m = (totalSecs % 3600) / 60, s = totalSecs % 60;
            if (h > 0) return $"{h}h {m:00}m {s:00}s";
            if (m > 0) return $"{m}m {s:00}s";
            return $"{s}s";
        }
    }

    // My current league position, as an ordinal ("3rd"), for the collapsed table header.
    private string MyRankText
    {
        get
        {
            if (Snap == null || Snap.MyIndex < 0) return "";
            int rank = 0;
            foreach (LeagueRow row in Snap.Table)
            {
                rank++;
                if (row.TeamIndex == Snap.MyIndex)
                    return rank switch { 1 => "1st", 2 => "2nd", 3 => "3rd", 21 => "21st", _ => $"{rank}th" };
            }
            return "";
        }
    }

    private string MyFormationName
    {
        get
        {
            if (Snap == null) return "";
            LeagueMemberView? me = Snap.Members.FirstOrDefault(m => m.Index == Snap.MyIndex);
            if (me != null && !string.IsNullOrEmpty(me.FormationName)) return me.FormationName;
            return Snap.MyFormation ?? "";
        }
    }

    private LegendPlayer? Lookup(string id) =>
        Config != null && Config.Legends.TryGetValue(LegendId.FromString(id), out LegendPlayer? p) ? p : null;

    private FormationInfo? MyFormationInfo =>
        Config != null && Snap != null && !string.IsNullOrEmpty(Snap.MyFormation)
        && Config.Formations.TryGetValue(FormationId.FromString(Snap.MyFormation), out FormationInfo? f) ? f : null;

    private int MyRosterCount => Snap?.MyRoster.Count ?? 0;

    private LegendPlayer? RosterLegendAt(int slot) =>
        Snap != null && Snap.MyRoster.TryGetValue(slot, out string? id) ? Lookup(id!) : null;

    private int RemainingFor(Position pos)
    {
        FormationInfo? f = MyFormationInfo;
        if (f == null || Snap == null) return 0;
        int need = f.CountOf(pos);
        int have = 0;
        for (int slot = 0; slot < f.Slots.Count; slot++)
            if (f.Slots[slot] == pos && Snap.MyRoster.ContainsKey(slot))
                have++;
        return need - have;
    }

    private List<Position> OpenPositions()
    {
        List<Position> open = new List<Position>();
        foreach (Position p in new[] { Position.GK, Position.DEF, Position.MID, Position.FWD })
            if (RemainingFor(p) > 0) open.Add(p);
        return open;
    }

    private Position ActivePickPos
    {
        get
        {
            List<Position> open = OpenPositions();
            if (open.Count == 0) return Position.GK;
            if (_pickPos.HasValue && open.Contains(_pickPos.Value)) return _pickPos.Value;
            return open[0];
        }
    }

    // The shared draft pool (one entry per real player), built once — matches the server's pool so a footballer
    // can only be drafted onto one team.
    private List<LegendPlayer>? _pool;
    private List<LegendPlayer> DraftPool =>
        _pool ??= (Config != null ? LeagueDraftEngine.BuildDraftPool(Config.Legends.Values.ToList()) : new List<LegendPlayer>());

    // ---- In-season hub overlays + claim badges ----
    private bool _showTransfers;
    private bool _showPass;
    private bool _showQuests;
    private bool _showInbox;
    private bool _showProfile;
    private bool _showResults;
    private bool _showHistory;
    private bool _showTable = true;

    private int UnreadMail => Player?.MailInbox.Count(m => !m.IsRead) ?? 0;

    // Objectives ready to claim (drives the 👤 Profile tile badge).
    private int ClaimableObjectives => Player != null ? Objectives.ClaimableCount(Player) : 0;
    // Incoming P2P trade offers awaiting my response (drives the Transfer Market tile badge).
    private int IncomingTrades => Snap?.MyTradeOffers.Count(o => o.Incoming) ?? 0;

    // ---- Matchday cinematic (feedback for PLAY MATCHDAY NOW — the sim "plays out" over ~10s) ----
    private const int CineFullTimeMinute = 93;
    private bool _cineWaiting;                 // play clicked, waiting for the result snapshot
    private int  _cineBaseMatchday;            // LastMatchdayNumber when play was clicked
    private bool _cineActive;
    private int  _cineMinute;
    private LeaguePlayResult? _cineResult;
    private readonly List<(int Minute, bool Mine, string Scorer, string Assist)> _cineGoals = new List<(int, bool, string, string)>();
    private System.Timers.Timer? _cineTimer;

    private void PlayMatchday()
    {
        _cineBaseMatchday = Snap?.LastMatchdayNumber ?? 0;
        _cineWaiting = true;
        MetaplayService.ClearMatchReward(); // so the FT screen shows THIS matchday's rewards
        MetaplayService.PlayLeagueFixture();
    }

    private int CineGoalsShown(bool mine)
    {
        int count = 0;
        foreach ((int minute, bool isMine, _, _) in _cineGoals)
            if (isMine == mine && minute <= _cineMinute)
                count++;
        return count;
    }

    private void StartCinematic(int matchday, LeaguePlayResult result)
    {
        _cineWaiting = false;
        _cineResult = result;
        _cineGoals.Clear();
        if (result.Goals != null && result.Goals.Count > 0)
        {
            // Real server-attributed goals: minute + named scorer/assister, mapped to my/opp perspective.
            foreach (MatchGoalDetail g in result.Goals)
                _cineGoals.Add((g.Minute, g.HomeSide == result.Home, g.Scorer, g.Assist));
        }
        else
        {
            // Fallback for results without goal detail: deterministic pseudo-random minutes, unnamed.
            for (int i = 0; i < result.MyGoals; i++)  _cineGoals.Add((CineMinute(matchday, i, 0), true, "", ""));
            for (int i = 0; i < result.OppGoals; i++) _cineGoals.Add((CineMinute(matchday, i, 1), false, "", ""));
        }
        _cineGoals.Sort((a, b) => a.Minute.CompareTo(b.Minute));
        _cineMinute = 0;
        _cineActive = true;
        _cineTimer?.Stop();
        _cineTimer?.Dispose();
        _cineTimer = new System.Timers.Timer(110) { AutoReset = true };
        _cineTimer.Elapsed += (_, _) =>
        {
            if (_cineMinute < CineFullTimeMinute)
            {
                _cineMinute++;
                OnStateChanged();
            }
            else
            {
                _cineTimer?.Stop();
            }
        };
        _cineTimer.Start();
    }

    private static int CineMinute(int matchday, int index, int side)
    {
        unchecked
        {
            uint h = (uint)(matchday * 7919 + index * 104729 + side * 1299721);
            h ^= h >> 13; h *= 2246822519u; h ^= h >> 16;
            return 1 + (int)(h % 90);
        }
    }

    private void SkipCinematic()
    {
        if (_cineActive && _cineMinute < CineFullTimeMinute)
            _cineMinute = CineFullTimeMinute;
    }

    private void CloseCinematic()
    {
        _cineActive = false;
        _cineResult = null;
        _cineTimer?.Stop();
        MetaplayService.ClearMatchReward();
    }

    // ---- Elite spin (gem-paid, guaranteed top-tier club) ----
    private LeagueDefinition Def =>
        Config != null && Config.LeagueDefinitions.TryGetValue(LeagueDefinitionId.FromString(LeagueDefinitionContent.DefaultId), out LeagueDefinition? def)
            ? def! : LeagueDefinitionContent.Default;
    private long EliteSpinCost => Def.EliteSpinGemCost;
    private bool CanAffordEliteSpin => (Player?.Wallet.Get(CurrencyType.Gems) ?? 0) >= EliteSpinCost;

    /// <summary> OVR for display — masked as "?" in a hard-mode (hidden-ratings) league. </summary>
    private string OvrText(int ovr) => (Snap?.HideRatings ?? false) ? "?" : ovr.ToString();

    private string ToggleStyle(bool on) => on
        ? "background:rgba(52,211,154,0.16);border:1px solid var(--t38-emerald);color:var(--t38-emerald);"
        : "background:rgba(255,255,255,0.05);border:1px solid var(--t38-line);color:rgba(255,255,255,0.6);";

    // ---- Custom squad-cap rules (the "House rules → Squad caps" editor) ----
    private void AddRule()
    {
        // Seed the new rule a notch below the current lowest band (or a sensible first band) so it reads in order.
        int ovr = _capRules.Count > 0 ? System.Math.Clamp(_capRules.Min(r => r.Ovr) - 5, 50, 99) : 85;
        _capRules.Add(new CapRule(ovr, 3));
    }
    private void RemoveRule(int idx) { if (idx >= 0 && idx < _capRules.Count) _capRules.RemoveAt(idx); }
    private void ToggleCaps()
    {
        // Off → seed the classic tester bands; On → clear to no caps.
        if (_capRules.Count > 0)
            _capRules.Clear();
        else
            _capRules.AddRange(new[] { new CapRule(90, 2), new CapRule(80, 3), new CapRule(75, 4) });
    }
    private void SetOvr(int idx, string? v) { if (idx >= 0 && idx < _capRules.Count && int.TryParse(v, out int n)) _capRules[idx].Ovr = System.Math.Clamp(n, 50, 99); }
    private void SetMax(int idx, string? v) { if (idx >= 0 && idx < _capRules.Count && int.TryParse(v, out int n)) _capRules[idx].Max = System.Math.Clamp(n, 1, 11); }

    // Shared "House rules" editor — used on BOTH the multiplayer create card and the single-player card.
    private RenderFragment RulesEditor => @<div class="t38-card px-3 py-2.5 flex flex-col gap-2" style="background:rgba(255,255,255,0.02);">
        <span class="t38-label text-[10px] text-white/45">House rules — pick your game mode</span>
        <label class="flex items-center justify-between gap-2 text-xs text-white/70">
            <span>🚫 Players per club</span>
            <select class="t38-input text-xs py-1.5 px-2" style="max-width:12rem;" @bind="_maxPerClub" data-testid="rule-club-select">
                <option value="0">No limit</option>
                <option value="1">Max 1 — one per club</option>
                <option value="2">Max 2 per club</option>
                <option value="3">Max 3 per club</option>
            </select>
        </label>
        <div class="flex flex-col gap-1.5" data-testid="rule-caps">
            <div class="flex items-center justify-between">
                <span class="text-xs text-white/70">🧮 Squad caps</span>
                <button class="text-[10px] px-2.5 py-1 rounded-lg t38-tap" style="@ToggleStyle(_capRules.Count > 0)"
                        data-testid="rule-caps-toggle" @onclick="ToggleCaps">@(_capRules.Count > 0 ? "ON" : "OFF")</button>
            </div>
            <p class="text-[10px] text-white/40 -mt-0.5">Limit your stars. Each rule caps how many players you can draft at or above a rating — stack a few for a tight budget XI.</p>
            @for (int i = 0; i < _capRules.Count; i++)
            {
                int idx = i;
                CapRule rule = _capRules[idx];
                <div class="flex items-center gap-1.5 text-xs text-white/75" data-testid="cap-rule">
                    <span class="text-white/40">max</span>
                    <input type="number" min="1" max="11" inputmode="numeric" value="@rule.Max"
                           class="t38-input text-xs py-1 px-1 text-center" style="width:2.8rem;"
                           @onchange="@(e => SetMax(idx, e.Value?.ToString()))" />
                    <span class="text-white/40">rated</span>
                    <input type="number" min="50" max="99" inputmode="numeric" value="@rule.Ovr"
                           class="t38-input text-xs py-1 px-1 text-center" style="width:3.4rem;"
                           @onchange="@(e => SetOvr(idx, e.Value?.ToString()))" />
                    <span class="text-white/40">+</span>
                    <button class="ml-auto text-white/35 hover:text-white/70 px-2 py-1 t38-tap" title="Remove rule"
                            data-testid="cap-rule-remove" @onclick="@(() => RemoveRule(idx))">✕</button>
                </div>
            }
            @if (_capRules.Count == 0)
            {
                <p class="text-[10px] text-white/30">No caps — draft whoever you like.</p>
            }
            @if (_capRules.Count < MaxCapRules)
            {
                <button class="text-[11px] py-1.5 rounded-lg t38-tap" style="background:rgba(255,255,255,0.05);color:rgba(255,255,255,0.7);"
                        data-testid="add-cap-rule" @onclick="AddRule">+ Add cap rule</button>
            }
        </div>
        <label class="flex items-center justify-between gap-2 text-xs text-white/70">
            <span>📅 Pin draft era</span>
            <select class="t38-input text-xs py-1.5 px-2" style="max-width:12rem;" @bind="_pinEra" data-testid="rule-era-select">
                <option value="">Any era</option>
                <option value="E2020s">2020s only</option>
                <option value="E2010s">2010s only</option>
                <option value="E2000s">2000s only</option>
                <option value="E1990s">90s classics</option>
            </select>
        </label>
        <button class="text-xs px-3 py-2 rounded-lg t38-tap flex items-center justify-between" data-testid="rule-elite-toggle"
                style="@ToggleStyle(_pinElite)" @onclick="@(() => _pinElite = !_pinElite)">
            <span>⭐ Elite clubs only</span><span style="font-weight:800;">@(_pinElite ? "ON" : "OFF")</span>
        </button>
        <button class="text-xs px-3 py-2 rounded-lg t38-tap flex items-center justify-between" data-testid="hardmode-toggle"
                style="@ToggleStyle(_hideRatings)" @onclick="@(() => _hideRatings = !_hideRatings)">
            <span>🙈 Hard mode — hide ratings</span><span style="font-weight:800;">@(_hideRatings ? "ON" : "OFF")</span>
        </button>
    </div>;

    /// <summary> "" if the spun player is legal to draft, else the squad-rule reason (no-same-club / OVR caps). </summary>
    private string RuleBlock(SpunPlayer pl)
    {
        if (Snap == null || Config == null) return "";
        LegendPlayer? cand = Lookup(pl.LegendId);
        if (cand == null) return "";
        Dictionary<int, string> roster = new Dictionary<int, string>();
        foreach ((int slot, string id) in Snap.MyRoster)
            roster[slot] = id;
        return LeagueDraftEngine.SquadRuleError(roster, lid => Lookup(lid.Value)!, Snap.MaxPerClub, LeagueDefinition.ParseOvrCaps(Snap.CapBands), cand);
    }

    /// <summary> Human-readable summary of the active squad-building rules (shown under the draft XI). </summary>
    private string RulesSummary()
    {
        if (Config == null) return "";
        List<string> parts = new List<string>();
        int mpc = Snap?.MaxPerClub ?? 0;
        if (mpc == 1) parts.Add("1 per club");
        else if (mpc > 1) parts.Add($"max {mpc}/club");
        List<(int Threshold, int Max)> caps = LeagueDefinition.ParseOvrCaps(Snap?.CapBands ?? "");
        if (caps.Count > 0) parts.Add("caps " + string.Join("/", caps.Select(c => $"{c.Max}×{c.Threshold}+")));
        string pin = LeaguePin.Describe(Snap?.DraftPin ?? "");
        if (pin.Length > 0) parts.Add("📌 " + pin);
        if (Snap?.HideRatings ?? false) parts.Add("🙈 ratings hidden");
        return string.Join(" · ", parts);
    }

    /// <summary> "Scorer 23', Scorer 45'" line for a result in the history view. </summary>
    private string ScorerLine(LeagueResultLine r) =>
        string.Join(", ", r.Goals.Select(g => $"{(string.IsNullOrEmpty(g.Scorer) ? "?" : ShortName(g.Scorer))} {g.Minute}'"));

    /// <summary> Completed-but-unclaimed quests across both scopes (daily gated on the stored day being current). </summary>
    private int ClaimableQuests
    {
        get
        {
            if (Player == null || Config == null) return 0;
            int count = 0;
            bool dayCurrent = Player.Quests.DayKey == QuestEngine.DayOf(Player.CurrentTime);
            if (dayCurrent)
            {
                foreach (QuestInfo def in QuestEngine.EffectiveDailySet(Config.Quests.Values, Player.Quests, Config.Global.DailyQuestSlots))
                    if (QuestEngine.IsComplete(def, Player.Quests) && !QuestEngine.IsClaimed(def, Player.Quests))
                        count++;
            }
            if (Player.Quests.SeasonScopeKey == (Player.League.Code ?? ""))
            {
                foreach (QuestInfo def in Config.Quests.Values)
                    if (def.Scope == QuestScope.Season && QuestEngine.IsComplete(def, Player.Quests) && !QuestEngine.IsClaimed(def, Player.Quests))
                        count++;
            }
            return count;
        }
    }

    /// <summary> Unlocked-but-unclaimed Season Pass tiers (free track + premium if owned). </summary>
    private int ClaimablePassTiers
    {
        get
        {
            if (Player == null || Config == null) return 0;
            GlobalConfig global = Config.Global;
            int tier = global.PassTier(Player.Pass.Xp);
            int free = System.Math.Max(0, System.Math.Min(tier, global.PassFreeRewards.Length) - Player.Pass.ClaimedFree);
            int premium = Player.Pass.PremiumOwned
                ? System.Math.Max(0, System.Math.Min(tier, global.PassPremiumRewards.Length) - Player.Pass.ClaimedPremium)
                : 0;
            return free + premium;
        }
    }

    private RenderFragment PitchRow(Position pos) => @<div class="flex justify-center gap-1.5 flex-wrap">
        @foreach (int s in SlotsFor(pos))
        {
            LegendPlayer? legend = RosterLegendAt(s);
            if (legend != null)
            {
                <div class="rounded-lg px-1 py-1 flex flex-col items-center" style="width:4.2rem;background:rgba(255,255,255,0.04);border:1px solid var(--t38-line);">
                    <span class="text-sm @PosTextClass(pos)" style="font-weight:800;">@OvrText(legend.Ovr)</span>
                    <span class="text-[9px] text-white/85 truncate w-full text-center">@ShortName(legend.Name)</span>
                </div>
            }
            else
            {
                <div class="rounded-lg flex flex-col items-center justify-center" style="width:4.2rem;height:3rem;border:1px dashed rgba(255,255,255,0.18);">
                    <span class="text-[8px] @PosTextClass(pos)" style="font-weight:700;">@PosShort(pos)</span>
                </div>
            }
        }
    </div>;

    private List<int> SlotsFor(Position pos)
    {
        List<int> idx = new List<int>();
        FormationInfo? f = MyFormationInfo;
        if (f == null) return idx;
        for (int s = 0; s < f.Slots.Count; s++)
            if (f.Slots[s] == pos) idx.Add(s);
        return idx;
    }

    private static string PosShort(Position p) => p switch { Position.GK => "GK", Position.DEF => "DEF", Position.MID => "MID", _ => "FWD" };
    private static string PosBgClass(Position p) => p switch { Position.GK => "t38-pos-gk", Position.DEF => "t38-pos-def", Position.MID => "t38-pos-mid", _ => "t38-pos-fwd" };
    private static string PosTextClass(Position p) => p switch
    {
        Position.GK => "text-[#e0b84e]", Position.DEF => "text-[#3b82f6]", Position.MID => "text-[#34d39a]", _ => "text-[#e0564f]"
    };
    private static string PosChipStyle(Position p, bool sel)
    {
        string c = p switch { Position.GK => "224,184,78", Position.DEF => "59,130,246", Position.MID => "52,211,154", _ => "224,86,79" };
        return sel
            ? $"background:rgb({c});color:#06140d;font-weight:700;"
            : $"background:rgba({c},0.14);color:rgb({c});";
    }

    private static string ShortName(string name)
    {
        if (string.IsNullOrEmpty(name)) return name;
        string[] parts = name.Split(' ');
        return parts.Length > 1 ? parts[parts.Length - 1] : name;
    }

    protected override void OnInitialized()
    {
        _mode = InitialMode is "join" or "solo" ? InitialMode : "create";
        _teamName = Player?.TeamName ?? ""; // remembered from a previous league
        MetaplayService.OnStateChanged += OnStateChanged;
        _refreshTimer = new System.Timers.Timer(3000) { AutoReset = true };
        _refreshTimer.Elapsed += (_, _) =>
        {
            if (Player?.League.InLeague == true)
                MetaplayService.RefreshLeague();
        };
        _refreshTimer.Start();
        // 1s repaint so the hero countdown ticks (tabular-nums keeps the digits steady).
        _tickTimer = new System.Timers.Timer(1000) { AutoReset = true };
        _tickTimer.Elapsed += (_, _) =>
        {
            if (Snap?.State == LeagueState.Active)
                OnStateChanged();
        };
        _tickTimer.Start();
        if (Player?.League.InLeague == true)
            MetaplayService.RefreshLeague();
    }

    private void OnStateChanged()
    {
        // The played matchday's snapshot + my fixture result arrive together (one PlayerSetLeagueState) —
        // that's the cue to roll the cinematic.
        if (_cineWaiting && Snap != null && Snap.LastMatchdayNumber > _cineBaseMatchday && Lg.LastPlayResult != null)
            StartCinematic(Snap.LastMatchdayNumber, Lg.LastPlayResult);
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        MetaplayService.OnStateChanged -= OnStateChanged;
        _refreshTimer?.Stop();
        _refreshTimer?.Dispose();
        _tickTimer?.Stop();
        _tickTimer?.Dispose();
        _cineTimer?.Stop();
        _cineTimer?.Dispose();
    }
}
