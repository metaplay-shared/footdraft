@namespace WebClientBase.Components.UI

<button type="@Type"
        class="@ComputedClass"
        style="@ComputedStyle"
        disabled="@Disabled"
        @onclick="OnClick"
        @attributes="AdditionalAttributes">
    @if (IsLoading)
    {
        <span class="loading loading-spinner loading-xs mr-2"></span>
    }
    @ChildContent
</button>

@code {
    /// <summary>
    /// Button variant for styling.
    /// </summary>
    public enum ButtonVariant
    {
        Primary,
        Secondary,
        Success,
        Danger,
        Warning
    }

    /// <summary>
    /// Button size.
    /// </summary>
    public enum ButtonSize
    {
        Small,
        Medium,
        Large
    }

    /// <summary>
    /// The button variant. Default: Primary
    /// </summary>
    [Parameter]
    public ButtonVariant Variant { get; set; } = ButtonVariant.Primary;

    /// <summary>
    /// The button size. Default: Medium
    /// </summary>
    [Parameter]
    public ButtonSize Size { get; set; } = ButtonSize.Medium;

    /// <summary>
    /// Whether the button is disabled.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Whether to show a loading spinner.
    /// </summary>
    [Parameter]
    public bool IsLoading { get; set; }

    /// <summary>
    /// Button type attribute. Default: "button"
    /// </summary>
    [Parameter]
    public string Type { get; set; } = "button";

    /// <summary>
    /// Click event callback.
    /// </summary>
    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    /// <summary>
    /// Additional CSS classes to apply.
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>
    /// Button content.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Additional HTML attributes.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string ComputedClass => $"rounded-lg font-medium transition-all flex items-center justify-center {SizeClass} {Class}";

    private string SizeClass => Size switch
    {
        ButtonSize.Small => "px-3 py-1.5 text-xs",
        ButtonSize.Large => "px-6 py-3 text-base",
        _ => "px-4 py-2 text-sm"
    };

    private string ComputedStyle
    {
        get
        {
            if (Disabled)
                return "background: var(--bg-hover); color: var(--text-muted); cursor: not-allowed; opacity: 0.5;";

            return Variant switch
            {
                ButtonVariant.Primary => "background: var(--accent-blue); color: white;",
                ButtonVariant.Secondary => "background: var(--bg-hover); color: var(--text-secondary);",
                ButtonVariant.Success => "background: var(--accent-green); color: white;",
                ButtonVariant.Danger => "background: rgba(239, 68, 68, 0.15); color: var(--accent-red);",
                ButtonVariant.Warning => "background: var(--accent-amber); color: white;",
                _ => "background: var(--accent-blue); color: white;"
            };
        }
    }
}
