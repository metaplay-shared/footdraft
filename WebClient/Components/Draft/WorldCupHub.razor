@using System.Collections.Generic
@using System.Linq
@using Game.Logic
@using Metaplay.Core
@using WebClientBase.Services
@inject MetaplayClientService MetaplayService
@implements IDisposable

@* FOOTDRAFT World Cup 2026: pay an entry fee → spin-draft a one-off XI from the real 48 national-team squads
   (the draft spins NATION buckets) → play the knockout (Round of 32 → Final) vs real nations of escalating
   strength for a reward ladder. State is PlayerModel.WorldCup + client-predicted actions (deterministic
   MatchSim), so the rounds resolve with no server round-trip. Reuses the spin-draft hub for the draft. *@

@if (Player == null || Config == null)
{
    <div class="t38-bg fixed inset-0 z-40 flex items-center justify-center"><p class="text-white/50">Loading…</p></div>
}
else if (_inDraft && Cup.State == WorldCupState.Drafting)
{
    @* Drafting the one-off World Cup XI — reuse the full spin-draft hub (server spins nation buckets). *@
    <DraftHub OnClose="@(() => _inDraft = false)" />
}
else
{
    <div class="t38-bg fixed inset-0 z-40 overflow-y-auto t38-under-hud" data-testid="worldcup-panel"
         style="padding-left:1rem;padding-right:1rem;padding-bottom:calc(7rem + env(safe-area-inset-bottom));">
        <div class="w-full mx-auto flex flex-col gap-3" style="max-width:30rem;">

            <div class="flex items-center justify-between pt-3">
                <h1 class="t38-display text-2xl text-white">🌍 WORLD CUP <span style="color:var(--t38-amber);">2026</span></h1>
                <button class="text-xs px-3 py-1.5 rounded-xl" style="background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.6);"
                        @onclick="OnClose">✕ CLOSE</button>
            </div>

            @if (Cup.State == WorldCupState.None || Cup.State == WorldCupState.Eliminated || Cup.State == WorldCupState.Champion)
            {
                @* ---------- Entry screen (also the re-enter screen after a finished run) ---------- *@
                @if (Cup.State == WorldCupState.Champion)
                {
                    <div class="t38-card px-5 py-5 flex flex-col items-center text-center" style="border-color:rgba(233,185,73,0.5);">
                        <span class="text-5xl mb-1">🏆</span>
                        <p class="t38-display text-xl" style="color:var(--t38-amber);">WORLD CHAMPIONS!</p>
                        <p class="text-xs text-white/55 mt-1">Won all @RoundsTotal rounds · beat @Cup.LastOpponent @Cup.LastMyGoals–@Cup.LastOppGoals in the final</p>
                        @if (!string.IsNullOrEmpty(Cup.LastReport))
                        {
                            <p class="text-[11px] text-white/70 mt-1.5" style="font-style:italic;">@Cup.LastReport</p>
                        }
                    </div>
                }
                else if (Cup.State == WorldCupState.Eliminated)
                {
                    <div class="t38-card px-5 py-4 flex flex-col items-center text-center">
                        <p class="t38-display text-lg text-white/85">Knocked out</p>
                        <p class="text-xs text-white/55 mt-1">Lost @Cup.LastMyGoals–@Cup.LastOppGoals to @Cup.LastOpponent in the @WorldCup.RoundName(Global, Cup.RoundIndex)@(Cup.BestRoundReached >= 0 ? $" · best: {WorldCup.RoundName(Global, Cup.BestRoundReached)}" : "")</p>
                        @if (!string.IsNullOrEmpty(Cup.LastReport))
                        {
                            <p class="text-[11px] text-white/70 mt-1.5" style="font-style:italic;">@Cup.LastReport</p>
                        }
                    </div>
                }

                <div class="t38-card px-4 py-3 flex items-center gap-3">
                    <span class="text-3xl">🌍</span>
                    <p class="text-xs text-white/60">Draft a dream XI from the real 48-nation World Cup pool, then win @RoundsTotal knockout rounds — opponents are real nations, getting tougher every round.</p>
                </div>

                <button class="t38-cta text-base w-full py-3.5 t38-tap flex items-center justify-center gap-2" data-testid="enter-wc-standard"
                        @onclick="@(() => Enter(false))">
                    @(CanAfford(false) ? $"ENTER — 🪙 {Global.WorldCupEntryCoins}" : $"🪙 {Global.WorldCupEntryCoins} — GET COINS →")
                </button>
                <button class="t38-marquee-btn t38-shine text-base w-full py-3 t38-tap" data-testid="enter-wc-premium"
                        style="@(CanAfford(true) ? "" : "filter:grayscale(0.3) brightness(0.85);")"
                        @onclick="@(() => Enter(true))">
                    ⭐ PREMIUM — 💎 @Global.WorldCupEntryGems · +@Global.WorldCupPremiumBonusPct% rewards
                </button>

                <button class="t38-card px-4 py-2.5 flex items-center gap-3 t38-tap w-full text-left" data-testid="open-scout"
                        @onclick="@(() => _showPacks = true)">
                    <span class="text-2xl">🎒</span>
                    <div class="flex-1 min-w-0">
                        <div class="text-xs text-white" style="font-weight:700;">Open a Scout Pack</div>
                        <div class="text-[10px] text-white/45">@BoostText</div>
                    </div>
                    <span class="t38-label text-[9px] px-2 py-1 rounded-full" style="background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.7);">BOOST →</span>
                </button>

                @LeaderboardCard
                @RewardLadder(showProgress: false)
            }
            else if (Cup.State == WorldCupState.Drafting)
            {
                @* ---------- Drafting phase (DraftHub closed) ---------- *@
                @if (DraftComplete)
                {
                    <div class="t38-card px-5 py-5 flex flex-col items-center text-center">
                        <span class="text-4xl mb-1">✅</span>
                        <p class="t38-display text-lg text-white">Your World Cup XI is ready</p>
                        <p class="text-xs text-white/55 mt-1">Overall @MyOvr@(Cup.Premium ? " · ⭐ premium run" : "")</p>
                    </div>
                    @OpponentCard
                    <button class="t38-cta text-lg w-full py-4 t38-tap" data-testid="play-worldcup"
                            @onclick="@(() => MetaplayService.PlayWorldCupRound())">▶ PLAY @WorldCup.RoundName(Global, 0).ToUpperInvariant()</button>
                    <button class="text-xs text-white/45 py-1" @onclick="@(() => _inDraft = true)">✎ edit my XI</button>
                }
                else
                {
                    <div class="t38-card px-5 py-6 flex flex-col items-center text-center">
                        <span class="text-4xl mb-2">🌍</span>
                        <p class="t38-display text-lg text-white">Draft your World Cup XI</p>
                        <p class="text-xs text-white/45 mt-1 mb-4">Spin a nation, pick a player. Build 11 from the world's best — this XI plays the whole knockout.</p>
                        <button class="t38-cta text-lg w-full py-3.5 t38-tap" data-testid="open-wc-draft" @onclick="@(() => _inDraft = true)">DRAFT NOW&nbsp; →</button>
                    </div>
                }
                @RewardLadder(showProgress: false)
            }
            else if (Cup.State == WorldCupState.Active)
            {
                @* ---------- Knockout in progress ---------- *@
                <div class="t38-card px-5 py-4 flex flex-col items-center text-center @(Cup.Premium ? "t38-turn" : "")">
                    <span class="t38-label text-[10px] text-white/45">Round @(Cup.RoundIndex + 1) / @RoundsTotal@(Cup.Premium ? " · ⭐ premium" : "")</span>
                    <p class="t38-display text-2xl text-white mt-1">@WorldCup.RoundName(Global, Cup.RoundIndex)</p>
                </div>

                @BracketStrip
                @OpponentCard

                @if (Cup.RoundIndex > 0 || Cup.LastMyGoals + Cup.LastOppGoals > 0)
                {
                    <div class="t38-card px-4 py-3 text-center" data-testid="worldcup-result">
                        <span class="t38-label text-[10px] text-white/40">last round · @Cup.LastOpponent</span>
                        <p class="t38-display text-2xl text-white mt-1">@Cup.LastMyGoals – @Cup.LastOppGoals</p>
                        @if (!string.IsNullOrEmpty(Cup.LastScorers))
                        {
                            <p class="text-[11px] text-white/45 mt-0.5">⚽ @Cup.LastScorers</p>
                        }
                        @if (!string.IsNullOrEmpty(Cup.LastReport))
                        {
                            <p class="text-[11px] text-white/65 mt-1" style="font-style:italic;">@Cup.LastReport</p>
                        }
                    </div>
                }

                <button class="t38-cta text-lg w-full py-4 t38-tap" data-testid="play-worldcup"
                        @onclick="@(() => MetaplayService.PlayWorldCupRound())">▶ PLAY @WorldCup.RoundName(Global, Cup.RoundIndex).ToUpperInvariant()</button>

                @RewardLadder(showProgress: true)
            }
        </div>
    </div>
}

@if (_showPacks)
{
    <PacksHub OnClose="@(() => _showPacks = false)" />
}

@code {
    [Parameter] public EventCallback OnClose { get; set; }

    private bool _showPacks;
    private DraftBoosts Boosts => Player!.Boosts;
    private string BoostText => Boosts.Any
        ? $"Ready: 🎲 {Boosts.Rerolls} rerolls · ⭐ {Boosts.EliteSpins} elite spins"
        : "Get rerolls + elite spins for this draft";

    private PlayerModel? Player => MetaplayService.PlayerModel;
    private SharedGameConfig? Config => Player?.GameConfig;
    private GlobalConfig Global => Config!.Global;
    private WorldCupRun Cup => Player!.WorldCup;
    private DraftedSquad Draft => Player!.Draft;

    private bool _inDraft;

    private int RoundsTotal => WorldCup.RoundsTotal(Global);

    private bool DraftComplete =>
        Config != null && Draft.HasFormation
        && Config.Formations.TryGetValue(Draft.Formation, out FormationInfo? f) && Draft.IsComplete(f!);

    private int MyOvr
    {
        get
        {
            if (Player == null) return 0;
            LineRatings r = Player.ResolveDraftRatings();
            return System.Math.Clamp((r.Attack * 3 + r.Midfield * 3 + r.Defence * 3 + r.Goalkeeping) / 10, 0, 99);
        }
    }

    // The nation the player faces in the current round (deterministic — matches what the server will resolve).
    private NationInfo? NextOpp =>
        Player != null && Config != null ? WorldCup.OpponentNation(Cup.RunCount, Cup.RoundIndex, Global) : null;

    private long Coins => Player?.Wallet.Get(CurrencyType.Coins) ?? 0;
    private long Gems  => Player?.Wallet.Get(CurrencyType.Gems) ?? 0;

    private bool CanAfford(bool premium) => premium ? Gems >= Global.WorldCupEntryGems : Coins >= Global.WorldCupEntryCoins;

    private void Enter(bool premium)
    {
        if (!CanAfford(premium)) { MetaplayService.RequestShop(); return; }
        MetaplayService.EnterWorldCup(premium);
        _inDraft = true; // jump straight into drafting the one-off XI
    }

    private int RewardPct => Cup.Premium ? 100 + Global.WorldCupPremiumBonusPct : 100;

    // "Road to the final" — the knockout path with rounds won (green) / current (amber) / upcoming (dim).
    private RenderFragment BracketStrip => @<div class="t38-card px-3 py-2.5" data-testid="wc-bracket">
        <span class="t38-label text-[9px] text-white/40">Road to the final</span>
        <div class="flex items-stretch gap-1 mt-1.5">
            @for (int i = 0; i < RoundsTotal; i++)
            {
                bool won = i <= Cup.BestRoundReached;
                bool now = Cup.State == WorldCupState.Active && i == Cup.RoundIndex;
                string col = won ? "var(--t38-emerald)" : now ? "var(--t38-amber)" : "rgba(255,255,255,0.12)";
                string txt = won ? "var(--t38-emerald)" : now ? "var(--t38-amber)" : "rgba(255,255,255,0.35)";
                <div class="flex-1 flex flex-col items-center">
                    <div class="w-full rounded" style="height:0.4rem;background:@col;"></div>
                    <span class="text-[7px] mt-1 text-center leading-tight" style="color:@txt;font-weight:700;">@ShortRound(i)</span>
                </div>
            }
        </div>
    </div>;

    private string ShortRound(int i)
    {
        string n = WorldCup.RoundName(Global, i) ?? "";
        if (n.Contains("32")) return "R32";
        if (n.Contains("16")) return "R16";
        if (n.StartsWith("Quarter")) return "QF";
        if (n.StartsWith("Semi")) return "SF";
        if (n.StartsWith("Final")) return "🏆";
        return n.Length > 4 ? n.Substring(0, 4) : n;
    }

    private RenderFragment OpponentCard => @<div class="t38-card px-4 py-3 flex items-center gap-3" data-testid="wc-opponent">
        @if (NextOpp is { } opp)
        {
            <span class="text-3xl">@opp.FlagEmoji</span>
            <div class="flex-1">
                <span class="t38-label text-[10px] text-white/40">your @WorldCup.RoundName(Global, Cup.RoundIndex) opponent</span>
                <div class="text-white" style="font-weight:800;">@opp.DisplayName</div>
            </div>
            <div class="text-right">
                <div class="t38-display text-xl" style="color:var(--t38-amber);">@opp.Strength</div>
                <span class="t38-label text-[8px] text-white/35">SQUAD OVR</span>
            </div>
        }
    </div>;

    private RenderFragment RewardLadder(bool showProgress) => @<div class="t38-card px-4 py-3 mt-1">
        <span class="t38-label text-[10px] text-white/45">Reward ladder@(Cup.Premium && showProgress ? " · ⭐ +" + Global.WorldCupPremiumBonusPct + "%" : "")</span>
        <div class="flex flex-col gap-1 mt-1">
            @for (int i = 0; i < Global.WorldCupRoundRewards.Length; i++)
            {
                BracketRoundReward rw = Global.WorldCupRoundRewards[i];
                bool won = showProgress && i <= Cup.BestRoundReached;
                bool nextUp = showProgress && Cup.State == WorldCupState.Active && i == Cup.RoundIndex;
                int pct = showProgress ? RewardPct : 100;
                <div class="flex items-center justify-between text-[11px] px-2 py-1 rounded"
                     style="@(won ? "background:rgba(52,211,154,0.14);color:var(--t38-emerald);" : nextUp ? "background:rgba(233,185,73,0.14);color:var(--t38-amber);" : "color:rgba(255,255,255,0.6);")">
                    <span>@(won ? "✓ " : nextUp ? "▶ " : "")@WorldCup.RoundName(Global, i)</span>
                    <span style="font-weight:700;">🪙@(rw.Coins * pct / 100) · 💎@(rw.Gems * pct / 100) · 🔷@(rw.Shards * pct / 100)</span>
                </div>
            }
        </div>
    </div>;

    private System.Timers.Timer? _repaint;

    private WorldCupLeaderboardSnapshot? Board => Player?.WcLeaderboard;
    private string RoundShort(int r) => r < 0 ? "—" : ShortRound(r);

    private RenderFragment LeaderboardCard => @<div class="t38-card px-4 py-3 mt-1" data-testid="wc-leaderboard">
        <div class="flex items-center justify-between">
            <span class="t38-label text-[10px] text-white/45">🏆 World Cup leaderboard</span>
            @if (Board is { MyRank: > 0 } b)
            {
                <span class="text-[11px]" style="color:var(--t38-amber);">you're #@b.MyRank / @b.TotalPlayers</span>
            }
        </div>
        @if (Board == null || Board.Top.Count == 0)
        {
            <p class="text-[11px] text-white/40 mt-1">No champions yet — be the first to make history.</p>
        }
        else
        {
            <div class="flex flex-col gap-0.5 mt-1.5">
                @foreach (WcLeaderboardEntry e in Board.Top.Take(10))
                {
                    <div class="flex items-center gap-2 text-[11px] py-0.5">
                        <span class="w-5 text-white/40" style="font-weight:700;">@e.Rank</span>
                        <span class="flex-1 truncate text-white/85">@e.Name</span>
                        <span class="text-white/55">@e.Titles 🏆</span>
                        <span class="text-white/40" style="min-width:2.2rem;text-align:right;">@RoundShort(e.BestRound)</span>
                    </div>
                }
            </div>
        }
    </div>;

    protected override void OnInitialized()
    {
        MetaplayService.OnStateChanged += OnStateChanged;
        MetaplayService.RefreshWorldCupLeaderboard(); // fetch the global board for the entry screen
        _repaint = new System.Timers.Timer(350) { AutoReset = true };
        _repaint.Elapsed += (_, _) => InvokeAsync(StateHasChanged);
        _repaint.Start();
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        MetaplayService.OnStateChanged -= OnStateChanged;
        _repaint?.Stop();
        _repaint?.Dispose();
    }
}
